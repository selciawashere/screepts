                            end

                            local userIdStr = tostring(LocalPlayer.UserId):sub(2, 4) .. tostring(coroutine.running()):sub(11, 15)
                            ReplicatedStorage.Modules.Net["RE/RegisterHit"]:FireServer(targetHead, attackTargets, {}, userIdStr)

