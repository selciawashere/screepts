    if ok and type(fruitData) == "table" then
        for _, fruitInfo in ipairs(fruitData) do
            if type(fruitInfo) == "table" and type(fruitInfo.Name) == "string" then
                local storageName = fruitInfo.Name
                local shortName = getShortFruitName(storageName)

                addFruitLookupAlias(lookup, storageName, storageName)
                addFruitLookupAlias(lookup, storageName .. " Fruit", storageName)
                addFruitLookupAlias(lookup, shortName, storageName)
                addFruitLookupAlias(lookup, shortName .. " Fruit", storageName)
            end
        end
    end

    for aliasName, storageName in pairs(FruitNameAliases) do
        addFruitLookupAlias(lookup, aliasName, storageName)
    end

    fruitStorageNameLookup = lookup
