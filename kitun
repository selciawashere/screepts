local function flattenLookVector(lookVector)
    local flat = Vector3.new(lookVector.X, 0, lookVector.Z)
    if flat.Magnitude <= 0.001 then
        return Vector3.new(0, 0, -1)
    end

    return flat.Unit
end

local function getGroundedMobAnchor(targetCFrame, enemyRoot, humanoid, fallbackCFrame)
    local baseCFrame = isUsableTargetCFrame(targetCFrame) and targetCFrame or fallbackCFrame
    if not isUsableTargetCFrame(baseCFrame) then
        return nil
    end

    local probeOrigin = baseCFrame.Position + Vector3.new(0, BRING_GROUND_PROBE_HEIGHT, 0)
    local groundedPosition = baseCFrame.Position

    updateBringGroundRaycastFilter()

    local raycastResult = Workspace:Raycast(
        probeOrigin,
        Vector3.new(0, -BRING_GROUND_PROBE_DEPTH, 0),
        bringGroundRaycastParams
    )

    if raycastResult then
        local clearance = BRING_GROUND_MIN_CLEARANCE
        if humanoid then
            clearance = math.clamp((humanoid.HipHeight or 0) + 2.5, BRING_GROUND_MIN_CLEARANCE, 6)
        end

        groundedPosition = Vector3.new(
            baseCFrame.Position.X,
            raycastResult.Position.Y + clearance,
            baseCFrame.Position.Z
        )
    end

    local facing = flattenLookVector(baseCFrame.LookVector)
    return CFrame.lookAt(groundedPosition, groundedPosition + facing)
end

function requestEntrance(teleportPos)
    if typeof(teleportPos) == "CFrame" then
        teleportPos = teleportPos.Position
    elseif typeof(teleportPos) ~= "Vector3" then
        return false
    end

    local now = os.clock()
    if lastEntranceRequestPos and (lastEntranceRequestPos - teleportPos).Magnitude <= 10 and now - lastEntranceRequestAt < 1 then
        return false
    end

    lastEntranceRequestPos = teleportPos
    lastEntranceRequestAt = now

    pcall(function()
        CommF:InvokeServer("requestEntrance", teleportPos)
    end)

    local hrp = getHumanoidRootPart()
    if hrp then
        hrp.CFrame = hrp.CFrame + Vector3.new(0, 50, 0)
    end

    task.wait(0.4)
    return true
end

function shouldRequestQuestEntrance(questCFrame, entrancePos, targetDistanceThreshold, entranceRadius)
    local hrp = getHumanoidRootPart()
    if not hrp or typeof(questCFrame) ~= "CFrame" then
        return false
    end

    local targetDistance = (questCFrame.Position - hrp.Position).Magnitude
    local entranceDistance = (entrancePos - hrp.Position).Magnitude
    return targetDistance > (targetDistanceThreshold or 10000)
        and entranceDistance > (entranceRadius or 350)
end

isUsableTargetCFrame = function(value)
    if typeof(value) ~= "CFrame" then
        return false
    end

    local position = value.Position
    if position.X ~= position.X or position.Y ~= position.Y or position.Z ~= position.Z then
        return false
    end

    return position.Magnitude > 0.5
end

