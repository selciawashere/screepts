local StyleInfoByKey = {}

local function normalizeStyleLookupName(name)
    if type(name) ~= "string" then
        return nil
    end

    return string.lower((name:gsub("[^%w]+", "")))
end

local function collectStyleLookupNames(styleInfo)
    local lookup = {}

    local function addName(name)
        local normalized = normalizeStyleLookupName(name)
        if normalized then
            lookup[normalized] = true
        end
    end

    addName(styleInfo.Name)
    addName(styleInfo.Key)

    for _, name in ipairs(styleInfo.ToolNames or {}) do
        addName(name)
    end

    return lookup
end

for _, styleInfo in ipairs(Sea1StyleProgression) do
    styleInfo.LookupNames = collectStyleLookupNames(styleInfo)
    StyleInfoByKey[styleInfo.Key] = styleInfo
end

local function markStyleOwnedByKey(styleKey, visited)
    if type(styleKey) ~= "string" then
        return
    end

    visited = visited or {}
    if visited[styleKey] then
        return
    end

    visited[styleKey] = true
    ownedStyleKeys[styleKey] = true

    local styleInfo = StyleInfoByKey[styleKey]
    if not styleInfo then
        return
    end

    for _, impliedKey in ipairs(styleInfo.ImpliedKeys or {}) do
        markStyleOwnedByKey(impliedKey, visited)
    end
end

local function extractResponseStrings(value, results, visited)
    results = results or {}
    visited = visited or {}

    if value == nil then
        return results
    end

    if type(value) == "string" then
        results[#results + 1] = string.lower(value)
        return results
    end

    if type(value) ~= "table" or visited[value] then
        return results
    end

    visited[value] = true

    for key, nestedValue in pairs(value) do
        extractResponseStrings(key, results, visited)
        extractResponseStrings(nestedValue, results, visited)
    end

    return results
end

local function refreshStyleInventoryCache(forceRefresh)
    if not forceRefresh and os.clock() < styleInventoryCache.nextRefreshAt then
        return styleInventoryCache.names
    end

    local ownedNames = {}
    local ok, inventory = pcall(function()
        return CommF:InvokeServer("getInventory")
    end)

    if ok and type(inventory) == "table" then
        for _, item in ipairs(inventory) do
            if type(item) == "table" then
                local itemName = item.Name or item.name
                local normalizedName = normalizeStyleLookupName(itemName)
                if normalizedName then
                    ownedNames[normalizedName] = true
                end
            end
        end
    end

    styleInventoryCache.names = ownedNames
    styleInventoryCache.nextRefreshAt = os.clock() + 2.5
    return ownedNames
end

local function refreshDetailedInventoryCache(forceRefresh)
    if not forceRefresh and os.clock() < detailedInventoryCache.nextRefreshAt then
        return detailedInventoryCache.items
    end

    local inventoryItems = {}
    local ok, inventory = pcall(function()
        return CommF:InvokeServer("getInventory")
    end)

    if ok and type(inventory) == "table" then
        inventoryItems = inventory
    end

    detailedInventoryCache.items = inventoryItems
    detailedInventoryCache.nextRefreshAt = os.clock() + 2.5
    return inventoryItems
end

local function hasOwnedStyle(styleInfo)
    if not styleInfo then
        return false
    end

    if ownedStyleKeys[styleInfo.Key] then
        return true
    end

    if hasToolNamed(styleInfo.ToolNames) then
        markStyleOwnedByKey(styleInfo.Key)
        return true
    end

    local inventoryNames = refreshStyleInventoryCache(false)
    for lookupName in pairs(styleInfo.LookupNames or {}) do
        if inventoryNames[lookupName] then
            markStyleOwnedByKey(styleInfo.Key)
            return true
        end
    end

    return false
end

local function purchaseResultLooksOwned(styleInfo, purchaseResults, beliBefore, fragmentsBefore)
    if not styleInfo then
        return false
    end

    local beliAfter = getCurrentBeli()
    local fragmentsAfter = getCurrentFragments()
    local didSpendCurrency = (beliAfter < beliBefore) or (fragmentsAfter < fragmentsBefore)
    local responseStrings = extractResponseStrings(purchaseResults)

    for _, text in ipairs(responseStrings) do
        local normalizedText = normalizeStyleLookupName(text) or ""
        local looksLikeOwnedResponse = text:find("already", 1, true)
            or text:find("equipped", 1, true)
            or text:find("equip", 1, true)
            or text:find("$0", 1, true)

        if looksLikeOwnedResponse then
            for lookupName in pairs(styleInfo.LookupNames or {}) do
                if normalizedText:find(lookupName, 1, true) then
                    return true
                end
            end

            return true
        end
    end

    return not didSpendCurrency and hasToolNamed(styleInfo.ToolNames)
end

