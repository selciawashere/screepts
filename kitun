performAutoM1 = function()
    if not isKaitunActionActive() then
        return
    end

    if os.clock() - lastAttackTick < SettingsFastAttack.FastAttackDelay then
        return
    end

    lastAttackTick = os.clock()

    local equippedTool = equipBestMeleeTool(true)
    if equippedTool then
        pcall(function()
            equippedTool:Activate()
        end)
    end

    clickAttack()
end

local function attackEnemy(enemy, offset, keepRunning)
    local humanoid = enemy and enemy:FindFirstChild("Humanoid")
    local enemyRoot = enemy and enemy:FindFirstChild("HumanoidRootPart")
    local head = enemy and enemy:FindFirstChild("Head")

    if not humanoid or not enemyRoot then
        return
    end

    repeat
        task.wait(ATTACK_LOOP_INTERVAL)

        if not isKaitunActionActive() then
            break
        end

        if shouldInterruptFarmForPriorityTask and shouldInterruptFarmForPriorityTask() then
            break
        end

        if not keepRunning() or not enemy.Parent or humanoid.Health <= 0 then
            break
        end

        if _G.AutoHaki then
            AutoHaki()
        end

        equipBestMeleeTool(true)

        MonFarm = enemy.Name
        PosMon = getGroundedMobAnchor(enemyRoot.CFrame, enemyRoot, humanoid, enemyRoot.CFrame) or enemyRoot.CFrame
        StartBring = true

        enemyRoot.CanCollide = false
        enemyRoot.Size = Vector3.new(60, 60, 60)
        humanoid.WalkSpeed = 0
        humanoid.JumpPower = 0

        if head then
            head.CanCollide = false
        end

        moveAboveTarget(PosMon, offset or FARM_HOLD_OFFSET)
        BringMob(enemy.Name)
        clickAttack()
    until not keepRunning()

    StartBring = false
end

local function runPriorityEnemyFight(enemyName, fallbackCFrame)
    if not isKaitunActionActive() then
        return false
    end

    local enemy = findNearestEnemy(enemyName)
    if not enemy then
        if isUsableTargetCFrame(fallbackCFrame) then
            moveToFarmPosition(fallbackCFrame, 25, true)
        end
        return false
    end

    state.suppressPriorityInterrupt = true
    attackEnemy(enemy, 30, function()
        local enemyHumanoid = enemy:FindFirstChild("Humanoid")
        return isKaitunActionActive()
            and state.running
            and enemy.Parent
            and enemyHumanoid
            and enemyHumanoid.Health > 0
    end)
    state.suppressPriorityInterrupt = false
    return true
end

local function runPriorityEnemyFightByNames(enemyNames, fallbackCFrame)
    if type(enemyNames) ~= "table" then
        return runPriorityEnemyFight(enemyNames, fallbackCFrame)
    end

    if not isKaitunActionActive() then
        return false
    end

    local enemy = findNearestEnemyByNames(enemyNames)
    if not enemy then
        if isUsableTargetCFrame(fallbackCFrame) then
