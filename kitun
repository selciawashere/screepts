local function getDesertBurnDoorInfo()
    local map = Workspace:FindFirstChild("Map")
    local desert = map and map:FindFirstChild("Desert")
    local burnFolder = desert and desert:FindFirstChild("Burn")

    if not burnFolder then
        return nil
    end

    local burnDoorContainer = burnFolder:FindFirstChild("Part")
    local targetParts = {}

    local function appendTargetPart(instance)
        if instance and instance:IsA("BasePart") then
            table.insert(targetParts, instance)
        end
    end

    if burnDoorContainer then
        appendTargetPart(burnDoorContainer)
        for _, child in ipairs(burnDoorContainer:GetDescendants()) do
            appendTargetPart(child)
        end
    else
        for _, child in ipairs(burnFolder:GetDescendants()) do
            appendTargetPart(child)
        end
    end

    if #targetParts == 0 then
        return nil
    end

    local referencePart = targetParts[1]
    local lowestTransparency = 1

    for _, part in ipairs(targetParts) do
        lowestTransparency = math.min(lowestTransparency, math.clamp(part.Transparency or 0, 0, 1))
    end

    return {
        part = referencePart,
        transparency = lowestTransparency,
        isOpen = lowestTransparency >= 1,
    }
end

local function isDesertBurnOpen()
    local doorInfo = getDesertBurnDoorInfo()
    return doorInfo and doorInfo.isOpen or false
end

local function isJungleFinalOpen()
    local map = Workspace:FindFirstChild("Map")
    local jungle = map and map:FindFirstChild("Jungle")
    local finalFolder = jungle and jungle:FindFirstChild("Final")

    if not finalFolder then
        return false
    end

    for _, child in ipairs(finalFolder:GetChildren()) do
        if child:IsA("BasePart") and child.Transparency == 1 then
            return true
        end
    end

    return false
end

local function getSaberProgressSnapshot()
    return {
        hasTorch = hasToolNamed({"Torch"}),
        hasCup = hasToolNamed({"Cup"}),
        hasRelic = hasToolNamed({"Relic"}),
        jungleFinalOpen = isJungleFinalOpen(),
    }
end

local function hasSaberInInventory()
    return hasOwnedSaber()
end

local function shouldContinueSaberAttempt(deadline)
    return isKaitunActionActive()
        and not state.autoSaberIgnored
        and not state.autoSaberCompleted
        and os.clock() <= deadline
end

local function resetAutoSaberProgressNotification()
    state.autoSaberNotifyKey = nil
end

local function notifyAutoSaberProgress(key, description, duration)
    if state.autoSaberNotifyKey == key then
        return
    end

    state.autoSaberNotifyKey = key
    notify("Saber", description, duration or 2.2)
end

local AutoSaberStageOrder = {
    need_cup = 1,
    cup_collected = 2,
    cup_filled = 3,
    sick_man_done = 4,
    rich_man_done = 5,
    relic_obtained = 6,
    relic_used = 7,
    jungle_open = 8,
}

local function setAutoSaberStage(stage)
    local currentStage = state.autoSaberStage
    local currentOrder = currentStage and AutoSaberStageOrder[currentStage] or 0
    local nextOrder = stage and AutoSaberStageOrder[stage] or 0

    if nextOrder > currentOrder then
        state.autoSaberStage = stage
    end
end

local function resolveAutoSaberStage(snapshot)
    if snapshot.jungleFinalOpen then
        setAutoSaberStage("jungle_open")
    elseif snapshot.hasRelic then
        setAutoSaberStage("relic_obtained")
    elseif snapshot.hasCup then
        setAutoSaberStage("cup_collected")
    elseif not state.autoSaberStage then
        state.autoSaberStage = "need_cup"
    end

    return state.autoSaberStage or "need_cup"
end

local function isAutoSaberCupExpected(stage)
    if stage == "cup_collected" then
        return true
    end

    return stage == "need_cup" and state.autoSaberBurnPhase == "burned"
end

local function shouldFallbackAutoSaberCup(stage, snapshot)
    local stageOrder = AutoSaberStageOrder[stage] or 0
    local cupRelevant = stageOrder > 0 and stageOrder <= AutoSaberStageOrder.cup_collected

    if not cupRelevant or snapshot.hasCup or not isAutoSaberCupExpected(stage) then
        state.autoSaberCupMissingSince = 0
        return false
    end

    if state.autoSaberCupMissingSince <= 0 then
        state.autoSaberCupMissingSince = os.clock()
        return false
    end

    if os.clock() - state.autoSaberCupMissingSince >= AUTO_SABER_CUP_MISSING_TIMEOUT then
        state.autoSaberCupMissingSince = 0
        return true
    end

    return false
end

local function ignoreAutoSaberForRun(reason)
    resetAutoSaberProgressNotification()
    state.autoSaberIgnored = true
    state.autoSaberBurnPhase = nil
    state.autoSaberStage = nil
    state.autoSaberCupMissingSince = 0
    abortKaitunActions()
    if reason and reason ~= "" then
        notify("Saber", reason, 2.5)
    end
end

local function completeAutoSaber()
    resetAutoSaberProgressNotification()
    state.autoSaberCompleted = true
    state.autoSaberBurnPhase = nil
    state.autoSaberStage = nil
    state.autoSaberCupMissingSince = 0
    abortKaitunActions()
    notify("Saber", "Saber obtained.", 2.5)
end

local function isSaberAttemptTimedOut(deadline)
    -- Do not auto-abandon Saber mid-chain; some runs legitimately take longer.
    return false
end

local function waitForToolByNames(names, timeout)
    local deadline = os.clock() + (timeout or 6)

    while os.clock() <= deadline do
        if not isKaitunActionActive() then
            abortKaitunActions()
            return false
        end

        if hasToolNamed(names) then
            return true
        end

        task.wait(0.15)
    end

    return hasToolNamed(names)
end

local function fillSaberCup()
    if not isKaitunActionActive() or not teleportAndWait(SaberQuestData.CupWater, 8, 12) then
        return false
    end

    notifyAutoSaberProgress("fill-cup", "Filling cup with water.")
    setAutoEquipLock({"Cup"})

    local cupTool = equipToolByNames({"Cup"})
    local equippedCup = cupTool and getCharacter():FindFirstChild("Cup") or nil
    if not equippedCup then
        clearAutoEquipLock()
        return false
    end

    invokeSaberQuestProgressRaw("ProQuestProgress", "FillCup", equippedCup)
    if not waitWithKaitunAbort(0.4) then
        clearAutoEquipLock()
        return false
    end
    invokeSaberQuestProgressRaw("ProQuestProgress")
    if not waitWithKaitunAbort(0.6) then
        clearAutoEquipLock()
        return false
    end
    clearAutoEquipLock()
    return true
end

local function performSaberTorchBurnSpin(torchTool, duration)
    local burnPosition = SaberQuestData.BurnDoor.Position
    local spinDeadline = os.clock() + (duration or 3.5)
    local spinStep = 0

    while os.clock() <= spinDeadline do
        if not isKaitunActionActive() then
            abortKaitunActions()
            return false
        end

        local hrp = getHumanoidRootPart()
        if not hrp then
            return false
        end

        spinStep = spinStep + 1
        hrp.CFrame = CFrame.new(burnPosition) * CFrame.Angles(0, math.rad((spinStep % 8) * 45), 0)

        if torchTool and torchTool.Parent == getCharacter() then
            pcall(function()
                torchTool:Activate()
            end)
        end

        task.wait(0.12)
    end

    return true
end

local function waitForEnemyByName(enemyName, timeout, anchorCFrame)
    local deadline = os.clock() + (timeout or 8)
    local enemy = findNearestEnemy(enemyName)

    while not enemy and os.clock() <= deadline do
        if not isKaitunActionActive() then
            abortKaitunActions()
            return nil
        end

        if isUsableTargetCFrame(anchorCFrame) then
            moveToFarmPosition(anchorCFrame, 25, true)
        end

        task.wait(0.2)
        enemy = findNearestEnemy(enemyName)
    end

    return enemy
end

local function runAutoSaber()
    if not shouldRunAutoSaber() then
        return false
    end

    abortKaitunActions()
    local saberDeadline = os.clock() + 30

    local snapshot = getSaberProgressSnapshot()
    local saberStage = resolveAutoSaberStage(snapshot)

    if shouldFallbackAutoSaberCup(saberStage, snapshot) then
        notifyAutoSaberProgress("cup-fallback-rich-man", "Cup missing for " .. tostring(AUTO_SABER_CUP_MISSING_TIMEOUT) .. " seconds. Skipping to Rich Man.")
        setAutoSaberStage("sick_man_done")
        saberStage = state.autoSaberStage
    end

    if snapshot.jungleFinalOpen then
        notifyAutoSaberProgress("fight-saber-expert", "Jungle door open. Moving to Saber Expert.")
        if not teleportAndWait(SaberQuestData.SaberBoss, 8, 10) then
            if isSaberAttemptTimedOut(saberDeadline) then
                ignoreAutoSaberForRun("Skipping Saber after 30 seconds.")
                return false
            end
            return true
        end

        local saberExpert = waitForEnemyByName("Saber Expert", math.min(8, math.max(saberDeadline - os.clock(), 0.5)), SaberQuestData.SaberBoss)
        if not saberExpert then
            if isSaberAttemptTimedOut(saberDeadline) then
                ignoreAutoSaberForRun("Skipping Saber after 30 seconds.")
                return false
            end
            return true
        end

        notifyAutoSaberProgress("fight-saber-expert-active", "Attacking Saber Expert.")
        state.suppressPriorityInterrupt = true
        attackEnemy(saberExpert, 30, function()
            local enemyHumanoid = saberExpert:FindFirstChild("Humanoid")
            return shouldContinueSaberAttempt(saberDeadline)
                and state.running
                and not hasSaberInInventory()
                and saberExpert.Parent
                and enemyHumanoid
                and enemyHumanoid.Health > 0
        end)
        state.suppressPriorityInterrupt = false
        if hasSaberInInventory() then
            completeAutoSaber()
            return false
        end
        if isSaberAttemptTimedOut(saberDeadline) then
            ignoreAutoSaberForRun("Skipping Saber after 30 seconds.")
            return false
        end
        return true
    end

    if saberStage == "need_cup" then
        if not state.autoSaberBurnPhase then
            notifyAutoSaberProgress("go-desert-door", "Checking desert burn door.")
            if not teleportAndWait(SaberQuestData.DesertDoor, 8, 15) then
                if isSaberAttemptTimedOut(saberDeadline) then
                    ignoreAutoSaberForRun("Skipping Saber after 30 seconds.")
                    return false
                end
                return true
            end

            local desertDoorInfo = getDesertBurnDoorInfo()
            local isBurnOpen = desertDoorInfo and desertDoorInfo.isOpen or false
            state.autoSaberBurnPhase = isBurnOpen and "burned" or "needs_burn"
        end

        if state.autoSaberBurnPhase == "needs_burn" then
            snapshot = getSaberProgressSnapshot()
            if not snapshot.hasTorch then
                notifyAutoSaberProgress("desert-plates", "Door not burned. Activating desert plates.")
                for index, plateCFrame in ipairs(SaberQuestData.PlatePositions) do
                    notifyAutoSaberProgress("desert-plate-" .. index, "Activating desert plate " .. index .. "/" .. #SaberQuestData.PlatePositions .. ".")
                    if not teleportAndWait(plateCFrame, 8, 8) then
                        if isSaberAttemptTimedOut(saberDeadline) then
                            ignoreAutoSaberForRun("Skipping Saber after 30 seconds.")
                            return false
                        end
                        return true
                    end
                    if not waitWithKaitunAbort(0.35) then
                        if not KaitunSettings.ToggleKaitunScript then
                            return false
                        end
                        if isSaberAttemptTimedOut(saberDeadline) then
                            ignoreAutoSaberForRun("Skipping Saber after 30 seconds.")
                            return false
                        end
                        return true
                    end
                end

                notifyAutoSaberProgress("collect-torch", "Collecting torch.")
                if not collectWorldTool({"Torch"}, SaberQuestData.TorchPickup, 30, 8) then
                    if isSaberAttemptTimedOut(saberDeadline) then
                        ignoreAutoSaberForRun("Skipping Saber after 30 seconds.")
                        return false
                    end
                    return true
                end

                if not waitForToolByNames({"Torch"}, math.min(8, math.max(saberDeadline - os.clock(), 0.5))) then
                    if isSaberAttemptTimedOut(saberDeadline) then
                        ignoreAutoSaberForRun("Skipping Saber after 30 seconds.")
                        return false
                    end
                    return true
                end

                snapshot = getSaberProgressSnapshot()
                if not snapshot.hasTorch then
                    return true
                end
            end

            notifyAutoSaberProgress("burn-door", "Burning desert door with torch.")
            if not teleportAndWait(SaberQuestData.BurnDoor, 8, 15) then
                if isSaberAttemptTimedOut(saberDeadline) then
                    ignoreAutoSaberForRun("Skipping Saber after 30 seconds.")
                    return false
                end
                return true
            end

            setAutoEquipLock({"Torch"})
            local torchTool = equipToolByNames({"Torch"})
            local equippedTorch = torchTool and getCharacter():FindFirstChild("Torch") or nil
            local equipDeadline = os.clock() + 3

            while not equippedTorch and os.clock() <= equipDeadline do
                if not isKaitunActionActive() then
                    clearAutoEquipLock()
                    abortKaitunActions()
                    return false
                end

                torchTool = equipToolByNames({"Torch"})
                equippedTorch = torchTool and getCharacter():FindFirstChild("Torch") or nil
                task.wait(0.15)
            end

            if equippedTorch then
                pcall(function()
                    equippedTorch:Activate()
                end)
            end

            if not performSaberTorchBurnSpin(equippedTorch, 3.5) then
                clearAutoEquipLock()
                if not KaitunSettings.ToggleKaitunScript then
                    return false
                end
                if isSaberAttemptTimedOut(saberDeadline) then
                    ignoreAutoSaberForRun("Skipping Saber after 30 seconds.")
                    return false
                end
                return true
            end

            if not waitWithKaitunAbort(1.2, 0.2) then
                clearAutoEquipLock()
                if not KaitunSettings.ToggleKaitunScript then
                    return false
                end
                if isSaberAttemptTimedOut(saberDeadline) then
                    ignoreAutoSaberForRun("Skipping Saber after 30 seconds.")
                    return false
                end
                return true
            end
            clearAutoEquipLock()

            state.autoSaberBurnPhase = "burned"
        end

        notifyAutoSaberProgress("collect-cup", "Burn complete. Collecting cup.")
        if not collectWorldTool({"Cup"}, SaberQuestData.CupPickup, 35, AUTO_SABER_CUP_PICKUP_TIMEOUT) then
            if state.autoSaberCupMissingSince <= 0 then
                state.autoSaberCupMissingSince = os.clock()
            end
            if isSaberAttemptTimedOut(saberDeadline) then
                ignoreAutoSaberForRun("Skipping Saber after 30 seconds.")
                return false
            end
            return true
        end

        snapshot = getSaberProgressSnapshot()
        if not snapshot.hasCup then
            if state.autoSaberCupMissingSince <= 0 then
                state.autoSaberCupMissingSince = os.clock()
            end
            return true
        end
        setAutoSaberStage("cup_collected")
        saberStage = state.autoSaberStage
    end

    snapshot = getSaberProgressSnapshot()
    saberStage = resolveAutoSaberStage(snapshot)
    if shouldFallbackAutoSaberCup(saberStage, snapshot) then
        notifyAutoSaberProgress("cup-fallback-rich-man", "Cup missing for " .. tostring(AUTO_SABER_CUP_MISSING_TIMEOUT) .. " seconds. Skipping to Rich Man.")
        setAutoSaberStage("sick_man_done")
        saberStage = state.autoSaberStage
    end

    if AutoSaberStageOrder[saberStage] < AutoSaberStageOrder.relic_obtained then
        if saberStage == "cup_collected" then
            if not snapshot.hasCup then
                return true
            end

            if not fillSaberCup() then
                if not KaitunSettings.ToggleKaitunScript then
                    return false
                end
                if isSaberAttemptTimedOut(saberDeadline) then
                    ignoreAutoSaberForRun("Skipping Saber after 30 seconds.")
                    return false
                end
                return true
            end

            setAutoSaberStage("cup_filled")
            saberStage = state.autoSaberStage
        end

        if saberStage == "cup_filled" then
            notifyAutoSaberProgress("visit-sick-man", "Cup filled. Visiting Sick Man.")
            if not teleportAndWait(SaberQuestData.SickMan, 8, 12) then
                if isSaberAttemptTimedOut(saberDeadline) then
                    ignoreAutoSaberForRun("Skipping Saber after 30 seconds.")
                    return false
                end
                return true
            end
            invokeSaberQuestProgress("SickMan")
            if not waitWithKaitunAbort(0.5) then
                if not KaitunSettings.ToggleKaitunScript then
                    return false
                end
                if isSaberAttemptTimedOut(saberDeadline) then
                    ignoreAutoSaberForRun("Skipping Saber after 30 seconds.")
                    return false
                end
                return true
            end
            setAutoSaberStage("sick_man_done")
            saberStage = state.autoSaberStage
        end

        if saberStage == "sick_man_done" then
            notifyAutoSaberProgress("visit-rich-man", "Talking to Rich Man.")
            if not teleportAndWait(SaberQuestData.RichMan, 8, 15) then
                if isSaberAttemptTimedOut(saberDeadline) then
                    ignoreAutoSaberForRun("Skipping Saber after 30 seconds.")
                    return false
                end
                return true
            end
            invokeSaberQuestProgress("RichSon")
            if not waitWithKaitunAbort(0.5) then
                if not KaitunSettings.ToggleKaitunScript then
                    return false
                end
                if isSaberAttemptTimedOut(saberDeadline) then
                    ignoreAutoSaberForRun("Skipping Saber after 30 seconds.")
                    return false
                end
                return true
            end
            setAutoSaberStage("rich_man_done")
            saberStage = state.autoSaberStage
        end

        if saberStage == "rich_man_done" then
            snapshot = getSaberProgressSnapshot()
            if snapshot.hasRelic then
                setAutoSaberStage("relic_obtained")
                saberStage = state.autoSaberStage
            else
                notifyAutoSaberProgress("fight-mob-leader", "Relic missing. Hunting Mob Leader.")
                if not runPriorityEnemyFight("Mob Leader", SaberQuestData.MobLeader) then
                    if isSaberAttemptTimedOut(saberDeadline) then
                        ignoreAutoSaberForRun("Skipping Saber after 30 seconds.")
                        return false
                    end
                    return true
                end
                if not waitWithKaitunAbort(0.5) then
                    if not KaitunSettings.ToggleKaitunScript then
                        return false
                    end
                    if isSaberAttemptTimedOut(saberDeadline) then
                        ignoreAutoSaberForRun("Skipping Saber after 30 seconds.")
                        return false
                    end
                    return true
                end

                if not teleportAndWait(SaberQuestData.RichMan, 8, 15) then
                    if isSaberAttemptTimedOut(saberDeadline) then
                        ignoreAutoSaberForRun("Skipping Saber after 30 seconds.")
                        return false
                    end
                    return true
                end
                invokeSaberQuestProgress("RichSon")
                if not waitWithKaitunAbort(0.5) then
                    if not KaitunSettings.ToggleKaitunScript then
                        return false
                    end
                    if isSaberAttemptTimedOut(saberDeadline) then
                        ignoreAutoSaberForRun("Skipping Saber after 30 seconds.")
                        return false
                    end
                    return true
                end
                invokeSaberQuestProgressRaw("ProQuestProgress")
                if not waitWithKaitunAbort(0.5) then
                    if not KaitunSettings.ToggleKaitunScript then
                        return false
                    end
                    if isSaberAttemptTimedOut(saberDeadline) then
                        ignoreAutoSaberForRun("Skipping Saber after 30 seconds.")
                        return false
                    end
                    return true
                end

                snapshot = getSaberProgressSnapshot()
                if not snapshot.hasRelic then
                    return true
                end
                setAutoSaberStage("relic_obtained")
                saberStage = state.autoSaberStage
            end
        end
    end

    if AutoSaberStageOrder[saberStage] < AutoSaberStageOrder.relic_obtained then
        snapshot = getSaberProgressSnapshot()
        if not snapshot.hasRelic then
            return true
        end
        setAutoSaberStage("relic_obtained")
        saberStage = state.autoSaberStage
    end

    if saberStage == "relic_used" then
        snapshot = getSaberProgressSnapshot()
        if not snapshot.jungleFinalOpen then
            notifyAutoSaberProgress("wait-jungle-door", "Relic used. Waiting for jungle door to open.")
            return true
        end
        setAutoSaberStage("jungle_open")
        return true
    end

    notifyAutoSaberProgress("open-relic-door", "Using relic at jungle door.")
    setAutoEquipLock({"Relic"})
    equipToolByNames({"Relic"})
    if not teleportAndWait(SaberQuestData.RelicDoor, 8, 10) then
        clearAutoEquipLock()
        if isSaberAttemptTimedOut(saberDeadline) then
            ignoreAutoSaberForRun("Skipping Saber after 30 seconds.")
            return false
        end
        return true
    end
    if not waitWithKaitunAbort(0.6) then
        clearAutoEquipLock()
        if not KaitunSettings.ToggleKaitunScript then
            return false
        end
        if isSaberAttemptTimedOut(saberDeadline) then
            ignoreAutoSaberForRun("Skipping Saber after 30 seconds.")
            return false
        end
        return true
    end
    clearAutoEquipLock()
    setAutoSaberStage("relic_used")
    saberStage = state.autoSaberStage

    snapshot = getSaberProgressSnapshot()
    if not snapshot.jungleFinalOpen then
        notifyAutoSaberProgress("wait-jungle-door", "Relic used. Waiting for jungle door to open.")
        return true
    end
    setAutoSaberStage("jungle_open")
    return true
