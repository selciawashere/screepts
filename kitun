local function canProgressStyleKey(styleKey)
    if styleKey == "DarkStep" or styleKey == "Electric" or styleKey == "WaterKungFu" or styleKey == "DragonBreath" then
        local styleInfo = StyleInfoByKey[styleKey]
        return styleInfo ~= nil
            and getCurrentSeaIndex() >= (styleInfo.Sea or 1)
            and not hasOwnedStyle(styleInfo)
            and canAttemptStylePurchase(styleInfo)
    elseif styleKey == "Superhuman" then
        return getCurrentSeaIndex() >= 2
            and (
                (not hasOwnedStyle(StyleInfoByKey.DarkStep) and canAttemptStylePurchase(StyleInfoByKey.DarkStep))
                or (hasOwnedStyle(StyleInfoByKey.DarkStep) and (getBaseStyleMasteryValue("DarkStep") or 0) < 300 and findToolByNames(getBaseStyleTrainingNames("DarkStep")))
                or (not hasOwnedStyle(StyleInfoByKey.Electric) and canAttemptStylePurchase(StyleInfoByKey.Electric))
                or (hasOwnedStyle(StyleInfoByKey.Electric) and (getBaseStyleMasteryValue("Electric") or 0) < 300 and findToolByNames(getBaseStyleTrainingNames("Electric")))
                or (not hasOwnedStyle(StyleInfoByKey.WaterKungFu) and canAttemptStylePurchase(StyleInfoByKey.WaterKungFu))
                or (hasOwnedStyle(StyleInfoByKey.WaterKungFu) and (getBaseStyleMasteryValue("WaterKungFu") or 0) < 300 and findToolByNames(getBaseStyleTrainingNames("WaterKungFu")))
                or (not hasOwnedStyle(StyleInfoByKey.DragonBreath) and canAttemptStylePurchase(StyleInfoByKey.DragonBreath))
                or (hasOwnedStyle(StyleInfoByKey.DragonBreath) and (getBaseStyleMasteryValue("DragonBreath") or 0) < 300 and findToolByNames(getBaseStyleTrainingNames("DragonBreath")))
                or canAttemptStylePurchase(StyleInfoByKey.Superhuman)
            )
    elseif styleKey == "DeathStep" then
        return getCurrentSeaIndex() >= 2
            and (
                (not hasOwnedStyle(StyleInfoByKey.DarkStep) and canAttemptStylePurchase(StyleInfoByKey.DarkStep))
                or (hasOwnedStyle(StyleInfoByKey.DarkStep) and (getBaseStyleMasteryValue("DarkStep") or 0) < 450 and findToolByNames(getBaseStyleTrainingNames("DarkStep")))
                or canAttemptStylePurchase(StyleInfoByKey.DeathStep)
            )
    elseif styleKey == "SharkManKarate" then
        return getCurrentSeaIndex() >= 2
            and (
                (not hasOwnedStyle(StyleInfoByKey.WaterKungFu) and canAttemptStylePurchase(StyleInfoByKey.WaterKungFu))
                or (hasOwnedStyle(StyleInfoByKey.WaterKungFu) and (getBaseStyleMasteryValue("WaterKungFu") or 0) < 400 and findToolByNames(getBaseStyleTrainingNames("WaterKungFu")))
                or (hasOwnedStyle(StyleInfoByKey.WaterKungFu) and (getBaseStyleMasteryValue("WaterKungFu") or 0) >= 400 and canAttemptStylePurchase(StyleInfoByKey.SharkManKarate))
            )
    elseif styleKey == "ElectricClaw" then
        return getCurrentSeaIndex() >= 2
            and (
                (not hasOwnedStyle(StyleInfoByKey.Electric) and canAttemptStylePurchase(StyleInfoByKey.Electric))
                or (hasOwnedStyle(StyleInfoByKey.Electric) and (getBaseStyleMasteryValue("Electric") or 0) < 400 and findToolByNames(getBaseStyleTrainingNames("Electric")))
                or (getCurrentSeaIndex() >= 3 and hasOwnedStyle(StyleInfoByKey.Electric) and (getBaseStyleMasteryValue("Electric") or 0) >= 400 and canAttemptStylePurchase(StyleInfoByKey.ElectricClaw))
            )
    elseif styleKey == "DragonTalon" then
        return getCurrentSeaIndex() >= 2
            and (
                (not hasOwnedStyle(StyleInfoByKey.DragonBreath) and canAttemptStylePurchase(StyleInfoByKey.DragonBreath))
                or (hasOwnedStyle(StyleInfoByKey.DragonBreath) and (getBaseStyleMasteryValue("DragonBreath") or 0) < 400 and findToolByNames(getBaseStyleTrainingNames("DragonBreath")))
                or (getCurrentSeaIndex() >= 3 and hasOwnedStyle(StyleInfoByKey.DragonBreath) and (getBaseStyleMasteryValue("DragonBreath") or 0) >= 400 and canAttemptStylePurchase(StyleInfoByKey.DragonTalon))
            )
    elseif styleKey == "GodHuman" then
        if not hasOwnedStyle(StyleInfoByKey.Superhuman) then
            return canProgressStyleKey("Superhuman")
        end
        if not hasOwnedStyle(StyleInfoByKey.DeathStep) then
            return canProgressStyleKey("DeathStep")
        end
        if not hasOwnedStyle(StyleInfoByKey.SharkManKarate) then
            return canProgressStyleKey("SharkManKarate")
        end
        if not hasOwnedStyle(StyleInfoByKey.ElectricClaw) then
            return canProgressStyleKey("ElectricClaw")
        end
        if not hasOwnedStyle(StyleInfoByKey.DragonTalon) then
            return canProgressStyleKey("DragonTalon")
        end

        return getCurrentSeaIndex() >= 3
            and (
                not hasGodHumanMaterialsReady()
                or canAttemptStylePurchase(StyleInfoByKey.GodHuman)
            )
    elseif styleKey == "SanguineArt" then
        return getCurrentSeaIndex() >= 3
            and hasInventoryItemNamed("Leviathan Heart")
            and canAttemptStylePurchase(StyleInfoByKey.SanguineArt)
    end

    return false
end

local function runStyleProgressForKey(styleKey)
    if styleKey == "DarkStep" or styleKey == "Electric" or styleKey == "WaterKungFu" or styleKey == "DragonBreath" then
        return runBaseStylePurchase(styleKey)
    elseif styleKey == "Superhuman" then
        return runAutoSuperhumanStyle()
    elseif styleKey == "DeathStep" then
        return runAutoDeathStepStyle()
    elseif styleKey == "SharkManKarate" then
        return runAutoSharkmanKarateStyle()
    elseif styleKey == "ElectricClaw" then
        return runAutoElectricClawStyle()
    elseif styleKey == "DragonTalon" then
        return runAutoDragonTalonStyle()
    elseif styleKey == "GodHuman" then
        return runAutoGodHumanStyle()
    elseif styleKey == "SanguineArt" then
        return runAutoSanguineArtStyle()
    end

    return false
end

local function getNextStyleProgressKey()
    for _, styleKey in ipairs(FightingStylePriorityKeys) do
        if KaitunSettings[styleKey] and not isStyleGoalSatisfied(styleKey) and canProgressStyleKey(styleKey) then
            return styleKey
        end
    end

    return nil
end

local function getNextSea1StyleTarget()
    local currentSea = getCurrentSeaIndex()

    for _, styleInfo in ipairs(Sea1StyleProgression) do
        local requiredSea = styleInfo.Sea or 1
        if KaitunSettings[styleInfo.Key]
            and currentSea >= requiredSea
            and not hasOwnedStyle(styleInfo)
        then
            return styleInfo
        end
    end

    return nil
end

local function canAttemptStylePurchase(styleInfo)
    if not styleInfo then
        return false
    end

    local levelOkay = not styleInfo.Level or getCurrentLevel() >= styleInfo.Level
    local beliOkay = not styleInfo.Beli or getCurrentBeli() >= styleInfo.Beli
    local fragmentsOkay = not styleInfo.Fragments or getCurrentFragments() >= styleInfo.Fragments
    return levelOkay and beliOkay and fragmentsOkay
end

shouldInterruptFarmForPriorityTask = function()
    if not KaitunSettings.ToggleKaitunScript then
        return false
    end

    if state.suppressPriorityInterrupt then
        return false
    end

    if shouldRunAutoSaber() then
        return true
    end

    if (KaitunSettings.AutoStoreFruit or KaitunSettings.AutoTweenFruit) and findStorableFruitTool() then
        return true
    end

    if KaitunSettings.AutoTweenFruit and not isInUnderwaterArea() then
        local fruitHandle = findNearestFruitSpawnHandle()
        if fruitHandle and fruitHandle.Parent then
            return true
        end
    end

    if getNextStyleProgressKey() then
        return true
    end

    if Sea1 and getCurrentLevel() >= 700 then
        return true
    end

    if Sea2Race.shouldRunTasks() then
        return true
    end

    return false
end

tryBuySea1Style = function(styleInfo)
    if not styleInfo or not canAttemptStylePurchase(styleInfo) then
        return false
    end

    if hasOwnedStyle(styleInfo) then
        return true
    end

    local lastAttempt = lastStyleAttemptAt[styleInfo.Key] or 0
    if os.clock() - lastAttempt < 1.5 then
        return false
    end

    lastStyleAttemptAt[styleInfo.Key] = os.clock()

    _G.AutoFarm = false
    StartBring = false
    stopFruitTween()
    stopTeleport()
    task.wait(0.15)

    notifyKaitunProgress("style-" .. tostring(styleInfo.Key), "Unlocking fighting style: " .. tostring(styleInfo.Name) .. ".", 2.2, "Fighting Style")

    if styleInfo.Entrance then
        requestEntrance(styleInfo.Entrance)
        task.wait(0.2)
    end

    if styleInfo.Position then
        moveToCFrame(styleInfo.Position + Vector3.new(0, 3, 0))
        task.wait(0.3)
    end

    local beliBefore = getCurrentBeli()
    local fragmentsBefore = getCurrentFragments()
    local purchaseResults = {}

    if styleInfo.RemoteArgsList then
        for _, remoteArgs in ipairs(styleInfo.RemoteArgsList) do
            pcall(function()
                purchaseResults[#purchaseResults + 1] = CommF:InvokeServer(unpack(remoteArgs))
            end)
            task.wait(0.1)
        end
    elseif styleInfo.RemoteArgs then
        pcall(function()
            purchaseResults[#purchaseResults + 1] = CommF:InvokeServer(unpack(styleInfo.RemoteArgs))
        end)
    end

    task.wait(0.35)

    refreshStyleInventoryCache(true)
    refreshDetailedInventoryCache(true)

    if hasOwnedStyle(styleInfo) or purchaseResultLooksOwned(styleInfo, purchaseResults, beliBefore, fragmentsBefore) then
        markStyleOwnedByKey(styleInfo.Key)
        notify("Fighting Style", "Unlocked " .. styleInfo.Name .. ".", 2.2)
        return true
    end

    return false
end

