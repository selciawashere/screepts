            Max = Vector3.new(70000, 7000, 15000),
        }
    elseif Sea2 then
        bounds = {
            Min = Vector3.new(-10000, -2500, -12000),
            Max = Vector3.new(12000, 7000, 36000),
        }
    else
        bounds = {
            Min = Vector3.new(-20000, -4000, -20000),
