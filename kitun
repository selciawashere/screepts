        moveToFarmPosition(Sea2Race.AlchemistCFrame, 8, true)

        local hrp = getHumanoidRootPart()
        if hrp and (hrp.Position - Sea2Race.AlchemistCFrame.Position).Magnitude <= 10 then
            pcall(function()
                CommF:InvokeServer("Alchemist", "3")
            end)
        end

        return true
    end

    if questStatus == 1 then
        if not hasToolNamed({"Flower 1"}) then
            local flower1 = Workspace:FindFirstChild("Flower1", true)
            notifyKaitunProgress("race-v2-flower1", "Collecting Flower 1.", 2.2, "Race V2")
            if flower1 and flower1:IsA("BasePart") then
                Sea2Race.touchCollectablePart(flower1)
            else
                moveToFarmPosition(Sea2Race.AlchemistCFrame, 20, true)
            end
            return true
        end

        if not hasToolNamed({"Flower 2"}) then
            local flower2 = Workspace:FindFirstChild("Flower2", true)
            notifyKaitunProgress("race-v2-flower2", "Collecting Flower 2.", 2.2, "Race V2")
            if flower2 and flower2:IsA("BasePart") then
                Sea2Race.touchCollectablePart(flower2)
            else
                moveToFarmPosition(Sea2Race.AlchemistCFrame, 20, true)
            end
            return true
        end

        if not hasToolNamed({"Flower 3"}) then
            notifyKaitunProgress("race-v2-flower3", "Farming Flower 3 from Zombies.", 2.2, "Race V2")
            if not runPriorityEnemyFight("Zombie", Sea2Race.ZombieFlowerCFrame) then
                moveToFarmPosition(Sea2Race.ZombieFlowerCFrame, 25, true)
            end
            return true
        end
    end

    notifyKaitunProgress("race-v2-start", "Starting Race V2 flower quest.", 2.2, "Race V2")
    moveToFarmPosition(Sea2Race.AlchemistCFrame, 8, true)

    local hrp = getHumanoidRootPart()
    if hrp and (hrp.Position - Sea2Race.AlchemistCFrame.Position).Magnitude <= 10 then
        pcall(function()
            CommF:InvokeServer("Alchemist", "2")
        end)
    end

    return true
end

function Sea2Race.findNearestChestPart()
    local hrp = getHumanoidRootPart()
    if not hrp then
        return nil
    end

    local bestChest = nil
    local bestDistance = math.huge

    for _, instance in ipairs(Workspace:GetDescendants()) do
        if instance:IsA("BasePart") and textContains(instance.Name, "Chest") then
            local distance = (instance.Position - hrp.Position).Magnitude
            if distance < bestDistance then
                bestDistance = distance
                bestChest = instance
            end
        end
    end

    return bestChest
end

function Sea2Race.findSeaBeastEnemy()
    return findNearestEnemy("Sea Beast")
end

function Sea2Race.runAutoRaceV3()
    if not KaitunSettings.AutoRaceV3
        or not Sea2
        or getCurrentLevel() < 1000
        or not Sea2Race.hasRaceV2()
        or Sea2Race.hasRaceV3()
    then
        return false
    end

    local currentRace = Sea2Race.normalizeRaceName(Sea2Race.getCurrentRaceName())

    if currentRace ~= "human"
        and currentRace ~= "rabbit"
        and currentRace ~= "shark"
        and currentRace ~= "cyborg"
    then
        return false
    end

    if not Sea2Race.hasDonSwanAccess() then
        if not Sea2Race.hasTrevorFruitAvailable() then
            return false
        end

        notifyKaitunProgress("race-v3-trevor", "Offering a stored fruit to Trevor for Don Swan access.", 2.2, "Race V3")
        Sea2Race.loadStoredFruitByFilter(function(storageName)
            return Sea2Race.TrevorFruitStorageNameSet[storageName] == true
        end)

        pcall(function()
            CommF:InvokeServer("TalkTrevor", "1")
            CommF:InvokeServer("TalkTrevor", "2")
            CommF:InvokeServer("TalkTrevor", "3")
        end)

        notifyKaitunProgress("race-v3-don-swan", "Defeating Don Swan for Race V3 access.", 2.2, "Race V3")
        if not runPriorityEnemyFight("Don Swan", Sea2Race.DonSwanBossCFrame) then
            moveToFarmPosition(Sea2Race.DonSwanBossCFrame, 20, true)
        end
        return true
    end

    local questStatus = Sea2Race.getRaceV3QuestStatus()
    if questStatus == nil or questStatus == -2 or questStatus == -1 then
        return false
    end

    if questStatus == 0 then
        notifyKaitunProgress("race-v3-start", "Starting Race V3 quest at Arowe.", 2.2, "Race V3")
        moveToFarmPosition(Sea2Race.AroweCFrame, 8, true)

        local hrp = getHumanoidRootPart()
        if hrp and (hrp.Position - Sea2Race.AroweCFrame.Position).Magnitude <= 10 then
            pcall(function()
                CommF:InvokeServer("Wenlocktoad", "2")
            end)
        end

        return true
    end

    if questStatus == 2 then
        notifyKaitunProgress("race-v3-claim", "Claiming Race V3 at Arowe.", 2.2, "Race V3")
        moveToFarmPosition(Sea2Race.AroweCFrame, 8, true)

        local hrp = getHumanoidRootPart()
        if hrp and (hrp.Position - Sea2Race.AroweCFrame.Position).Magnitude <= 10 then
            pcall(function()
                CommF:InvokeServer("Wenlocktoad", "3")
            end)
        end

        return true
    end

    if currentRace == "human" then
        for _, bossInfo in ipairs(Sea2Race.HumanRaceV3Bosses) do
            if findNearestEnemy(bossInfo.Name) then
                notifyKaitunProgress("race-v3-human-" .. bossInfo.Name, "Defeating " .. bossInfo.Name .. " for Human V3.", 2.2, "Race V3")
                runPriorityEnemyFight(bossInfo.Name, bossInfo.CFrame)
                return true
            end
        end

        state.secondSeaRaceBossIndex = ((state.secondSeaRaceBossIndex or 0) % #Sea2Race.HumanRaceV3Bosses) + 1
        local bossTarget = Sea2Race.HumanRaceV3Bosses[state.secondSeaRaceBossIndex]
        notifyKaitunProgress("race-v3-human-route", "Rotating Human V3 boss spawns.", 2.2, "Race V3")
        moveToFarmPosition(bossTarget.CFrame, 25, true)
        return true
    end

    if currentRace == "rabbit" then
        local chest = Sea2Race.findNearestChestPart()
        if chest then
            notifyKaitunProgress("race-v3-rabbit", "Collecting chests for Rabbit V3.", 2.2, "Race V3")
            Sea2Race.touchCollectablePart(chest)
            return true
        end

        moveToFarmPosition(Sea2Race.AroweCFrame, 12, true)
        return true
    end

    if currentRace == "shark" then
        local seaBeast = Sea2Race.findSeaBeastEnemy()
        if seaBeast then
            notifyKaitunProgress("race-v3-shark", "Defeating a natural Sea Beast for Shark V3.", 2.2, "Race V3")
            runPriorityEnemyFight("Sea Beast", seaBeast:GetPivot())
            return true
        end

        return false
    end

    if currentRace == "cyborg" then
        if not findStorableFruitTool() then
            Sea2Race.loadStoredFruitByFilter(function()
                return true
            end)
        end

        notifyKaitunProgress("race-v3-cyborg", "Showing a physical fruit to Arowe for Cyborg V3.", 2.2, "Race V3")
        moveToFarmPosition(Sea2Race.AroweCFrame, 8, true)

        local hrp = getHumanoidRootPart()
        if hrp and (hrp.Position - Sea2Race.AroweCFrame.Position).Magnitude <= 10 then
            pcall(function()
                CommF:InvokeServer("Wenlocktoad", "3")
            end)
        end

        return true
    end

    return false
end

function Sea2Race.shouldRunTasks()
    if not KaitunSettings.ToggleKaitunScript or not Sea2 then
        return false
    end

    if KaitunSettings.AutoRaceV2 and getCurrentLevel() >= 850 and not Sea2Race.hasRaceV2() then
        return true
    end

    if not KaitunSettings.AutoRaceV3
        or getCurrentLevel() < 1000
        or not Sea2Race.hasRaceV2()
        or Sea2Race.hasRaceV3()
    then
        return false
    end

    local currentRace = Sea2Race.normalizeRaceName(Sea2Race.getCurrentRaceName())
    if currentRace == "human" or currentRace == "rabbit" or currentRace == "cyborg" then
        return Sea2Race.hasDonSwanAccess() or Sea2Race.hasTrevorFruitAvailable()
    end

    if currentRace == "shark" then
        return (Sea2Race.hasDonSwanAccess() or Sea2Race.hasTrevorFruitAvailable()) and Sea2Race.findSeaBeastEnemy() ~= nil
    end

    return false
end

function Sea2Race.runProgression()
    if Sea2Race.runAutoRaceV2() then
        return true
    end

    if Sea2Race.runAutoRaceV3() then
        return true
    end

    return false
end

