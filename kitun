                            local humanoid = entity:FindFirstChild("Humanoid")

                            if entity ~= character and entityRoot and humanoid and humanoid.Health > 0 then
                                if (entityRoot.Position - rootPart.Position).Magnitude <= 60 then
                                    local targetHead = entity:FindFirstChild("Head")
                                    table.insert(attackTargets, {entity, targetHead or entityRoot})
                                    if targetHead and targetHead ~= entityRoot then
                                        table.insert(attackTargets, {entity, entityRoot})
                                    end
                                end
                            end
                        end
                    end
                end

                local tool = character:FindFirstChildOfClass("Tool")
                if #attackTargets > 0 then
                    tool = equipBestMeleeTool(false) or tool
                end

                if #attackTargets > 0 and tool then
                    local weaponType = tool:GetAttribute("WeaponType") or tool.ToolTip
