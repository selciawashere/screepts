local function clusterEnemies(primaryEnemy, enemyName)
    local enemiesFolder = getEnemiesFolder()
    local primaryRoot = primaryEnemy and primaryEnemy:FindFirstChild("HumanoidRootPart")

    if not enemiesFolder or not primaryRoot then
        return
    end

    for _, enemy in ipairs(enemiesFolder:GetChildren()) do
        if enemy ~= primaryEnemy and isTargetEnemy(enemy, enemyName) then
            local enemyRoot = enemy:FindFirstChild("HumanoidRootPart")
            if enemyRoot then
                enemyRoot.CanCollide = false
                enemyRoot.CFrame = primaryRoot.CFrame * CFrame.new(0, 0, -2)
            end
        end
    end
