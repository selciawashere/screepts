local function teleportAndWait(target, tolerance, timeout)
    local resolved = resolveTeleportTarget(target)
    local maxDistance = tolerance or 6
    local deadline = os.clock() + (timeout or 8)

    if not resolved or not isKaitunActionActive() then
        return false
    end

    while os.clock() <= deadline do
        if not isKaitunActionActive() then
            abortKaitunActions()
            return false
        end

        local hrp = getHumanoidRootPart()
        if hrp and (hrp.Position - resolved.Position).Magnitude <= maxDistance then
            stopTeleport()
            return true
        end

        TP1(resolved)
        task.wait(0.1)
    end

    local hrp = getHumanoidRootPart()
    return hrp and (hrp.Position - resolved.Position).Magnitude <= maxDistance or false
end

local function collectWorldTool(names, fallbackTarget, searchRadius, timeout)
    local resolvedFallback = resolveTeleportTarget(fallbackTarget)
    local nearPosition = resolvedFallback and resolvedFallback.Position or nil
    local deadline = os.clock() + (timeout or 6)

    while os.clock() <= deadline do
        if not isKaitunActionActive() then
            abortKaitunActions()
            return false
        end

        if hasToolNamed(names) then
            return true
        end

        local worldTool = findWorldToolByNames(names, nearPosition, searchRadius or 60)
        local handle = worldTool and getToolHandle(worldTool) or nil
        local pickupTarget = handle and handle.CFrame or resolvedFallback

        if pickupTarget then
            teleportAndWait(pickupTarget, 5, 4)

            local hrp = getHumanoidRootPart()
            if hrp and handle and firetouchinterest then
                pcall(firetouchinterest, hrp, handle, 0)
                pcall(firetouchinterest, hrp, handle, 1)
            end
        end

        task.wait(0.2)
    end

    return hasToolNamed(names)
end

