                                    end),
                                    bit32.bxor(fastAttackRemoteEventId + 909090, ReplicatedStorage.Modules.Net.seed:InvokeServer() * 2),
                                    targetHead,
                                    attackTargets
                                )
                            end
                        end)
                    end
                end
            end
        end
    end
end)

