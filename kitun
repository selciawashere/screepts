function Sea2Race.runBartiloColosseumQuest()
    local progress = Sea2Race.getBartiloQuestProgress()
    if progress == nil or progress == 3 then
        return false
    end

    if progress == 2 then
        notifyKaitunProgress("bartilo-colosseum-code", "Finishing Bartilo code puzzle.", 2.2, "Race V2")
        moveToFarmPosition(Sea2Race.BartiloCodeStartCFrame, 6, true)

        local hrp = getHumanoidRootPart()
        if hrp and (hrp.Position - Sea2Race.BartiloCodeStartCFrame.Position).Magnitude <= 12 then
            hrp.CFrame = Sea2Race.BartiloCodeStartCFrame
            task.wait(0.5)
            for _, stepCFrame in ipairs(Sea2Race.BartiloCodePath) do
                hrp.CFrame = stepCFrame
                task.wait(0.1)
            end
        end

        return true
    end

    if progress == 1 then
        notifyKaitunProgress("bartilo-jeremy", "Defeating Jeremy for Bartilo.", 2.2, "Race V2")
        if not runPriorityEnemyFight("Jeremy", Sea2Race.JeremyBossCFrame) then
            moveToFarmPosition(Sea2Race.JeremyBossCFrame, 25, true)
        end
        return true
    end

    local questTitleText = getQuestTitleText()
    local questGui = getQuestGui()
    local onBartiloSwanQuest = questGui
        and questGui.Visible
        and textContains(questTitleText, "Swan Pirates")

    if onBartiloSwanQuest then
        notifyKaitunProgress("bartilo-swan-pirates", "Defeating Swan Pirates for Bartilo.", 2.2, "Race V2")
        if not runPriorityEnemyFight("Swan Pirate", Sea2Race.BartiloSwanPirateCFrame) then
            moveToFarmPosition(Sea2Race.BartiloSwanPirateCFrame, 20, true)
        end
        return true
    end

    notifyKaitunProgress("bartilo-start", "Starting Bartilo quest chain.", 2.2, "Race V2")
    moveToFarmPosition(Sea2Race.BartiloNpcCFrame, 8, true)

    local hrp = getHumanoidRootPart()
    if hrp and (hrp.Position - Sea2Race.BartiloNpcCFrame.Position).Magnitude <= 10 then
        pcall(function()
            CommF:InvokeServer("StartQuest", "BartiloQuest", 1)
        end)
    end

    return true
end

