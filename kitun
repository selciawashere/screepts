tweenToCFrame = function(targetCFrame, speed)
    local hrp = getHumanoidRootPart()
    if not hrp or typeof(targetCFrame) ~= "CFrame" then
        return false
    end

    speed = math.max(tonumber(speed) or tonumber(state.tweenSpeed) or 320, 1)

    if activeFruitTweenTarget and (activeFruitTweenTarget.Position - targetCFrame.Position).Magnitude <= 4 and activeFruitTween then
        local playbackState = activeFruitTween.PlaybackState
        if playbackState == Enum.PlaybackState.Playing or playbackState == Enum.PlaybackState.Delayed then
            return true
        end
    end

    stopTeleport()
    stopFruitTween()

    local distance = (targetCFrame.Position - hrp.Position).Magnitude
    if distance <= 1.5 then
        return true
    end

    local tweenTime = math.max(distance / speed, 0.08)
    nextFruitTweenAt = os.clock() + tweenTime + 1
    activeFruitTweenTarget = targetCFrame
    activeFruitTween = TweenService:Create(hrp, TweenInfo.new(tweenTime, Enum.EasingStyle.Linear), {
        CFrame = targetCFrame
    })
    activeFruitTween:Play()
    return true
end

findNearestFruitSpawnHandle = function()
    local hrp = getHumanoidRootPart()
    local bestHandle = nil
    local bestDistance = math.huge

    for _, handle in ipairs(getFruitSpawnHandles()) do
        if handle and handle.Parent then
            local distance = hrp and (handle.Position - hrp.Position).Magnitude or 0
            if distance < bestDistance then
                bestDistance = distance
                bestHandle = handle
            end
        end
    end

