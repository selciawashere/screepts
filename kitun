task.spawn(function()
    while state.running do
        task.wait(0.1)
        _G.BringMonster = true
        _G.BringMob = true

        sanitizeTeleportState()

        if not KaitunSettings.ToggleKaitunScript then
            _G.AutoFarm = false
            StartBring = false
            clearAutoEquipLock()
            stopFruitTween()
            stopTeleport()
            continue
        end

        local nextStyleKey = nil
        local carriedFruitTool = findStorableFruitTool()
        local fruitHandle = nil
        local underwaterFruitBlocked = isInUnderwaterArea()
        local fruitAutomationEnabled = KaitunSettings.AutoStoreFruit or KaitunSettings.AutoBuyRandomFruit or KaitunSettings.AutoTweenFruit
        local activeTask = "idle"

        if isFruitTweenInProgress() then
            activeTask = "fruit_tween"
        end

        if KaitunSettings.ToggleKaitunScript then
            nextStyleKey = getNextStyleProgressKey()
        end

        if KaitunSettings.AutoRedeemCodes and not state.redeemedAllCodes then
            state.redeemedAllCodes = true
            task.spawn(function()
                pcall(redeemAllCodes)
            end)
        end

        if activeTask == "idle" and carriedFruitTool and fruitAutomationEnabled then
            activeTask = "store_fruit"
            _G.AutoFarm = false
            StartBring = false
            stopTeleport()
            stopFruitTween()
            if os.clock() - lastFruitStoreAt >= 1.5 then
                lastFruitStoreAt = os.clock()
                pcall(tryStoreCarriedFruit)
            end
        end

        if activeTask == "idle" or activeTask == "fruit_tween" then
            if underwaterFruitBlocked then
                stopFruitTween()
                if activeTask == "fruit_tween" then
                    activeTask = "idle"
                end
            elseif KaitunSettings.AutoTweenFruit and not carriedFruitTool then
                fruitHandle = findNearestFruitSpawnHandle()
                if fruitHandle and fruitHandle.Parent then
                    activeTask = "fruit_tween"
                    runAutoTweenFruitStep()
                else
                    stopFruitTween()
                    if activeTask == "fruit_tween" then
                        activeTask = "idle"
                    end
                end
            else
                stopFruitTween()
                if activeTask == "fruit_tween" then
                    activeTask = "idle"
                end
            end
        elseif underwaterFruitBlocked then
            stopFruitTween()
        end

        if activeTask == "idle" and shouldRunAutoSaber() then
            activeTask = "saber"
            runAutoSaber()
        end

        if activeTask == "idle" and KaitunSettings.ToggleKaitunScript and nextStyleKey then
            activeTask = "style"
            runStyleProgressForKey(nextStyleKey)
        end

        if activeTask == "idle" and KaitunSettings.ToggleKaitunScript and Sea1 and getCurrentLevel() >= 700 then
            activeTask = "second_sea"
            if not runAutoSecondSea() then
                activeTask = "idle"
            end
        end

        if activeTask == "idle" and Sea2Race.shouldRunTasks() then
            activeTask = "second_sea_race"
            if not Sea2Race.runProgression() then
                activeTask = "idle"
            end
        end

        if activeTask == "idle" and KaitunSettings.AutoBuyRandomFruit and os.clock() - lastFruitSpinAt >= 3 then
            fruitHandle = fruitHandle or findNearestFruitSpawnHandle()
            if not carriedFruitTool and not fruitHandle then
                activeTask = "buy_fruit"
                _G.AutoFarm = false
                StartBring = false
                stopTeleport()
                stopFruitTween()
                lastFruitSpinAt = os.clock()
                pcall(buyRandomFruit)
            end
        end

        local shouldFarm = KaitunSettings.ToggleKaitunScript

        if activeTask == "idle" and shouldFarm then
            clearAutoEquipLock()
            _G.AutoFarm = true
            runAutoLevelFarm()
        else
            _G.AutoFarm = false
            if activeTask ~= "second_sea" and activeTask ~= "second_sea_race" and activeTask ~= "style" and activeTask ~= "saber" then
                StartBring = false
            end
        end
    end
end)

