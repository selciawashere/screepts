local function setKaitunScriptEnabled(value)
    KaitunSettings.ToggleKaitunScript = value
    _G.AutoFarm = value
    state.autoSaberNotifyKey = nil
    state.autoSaberBurnPhase = nil
    state.autoSaberStage = nil
    state.autoSaberCupMissingSince = 0
    state.kaitunProgressKey = nil
    state.electricClawStage = 0

    if value then
        state.redeemedAllCodes = false
        state.autoSaberIgnored = false
        state.autoSaberCompleted = false
    else
        if abortKaitunActions then
            abortKaitunActions()
        else
            state.autoEquipLockNames = nil
            state.suppressPriorityInterrupt = false
            _G.AutoFarm = false
            StartBring = false
        end
        state.autoSaberIgnored = false
        state.autoSaberCompleted = false
    end
end

