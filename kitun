local function hasInventoryItemNamed(itemName)
    if type(itemName) ~= "string" then
        return false
    end

    if hasToolNamed({itemName}) then
        return true
    end

    local normalizedName = normalizeStyleLookupName(itemName)
    return normalizedName ~= nil and refreshStyleInventoryCache(false)[normalizedName] == true or false
end

local function getMaterialInventory()
    local materials = {}

    for _, item in ipairs(refreshDetailedInventoryCache(false)) do
        if type(item) == "table" then
            local itemName = item.Name or item.name
            local itemType = string.lower(tostring(item.Type or item.type or ""))
            local itemCount = tonumber(item.Count or item.count or item.Amount or item.amount or 1) or 1
            if type(itemName) == "string" and (itemType:find("material", 1, true) or itemCount > 1) then
                materials[itemName] = math.max(materials[itemName] or 0, itemCount)
            end
        end
    end

    return materials
end

local function getToolLevelByNames(names)
    if type(names) == "string" then
        names = {names}
    end

    local tool = findToolByNames(names or {})
    local levelValue = tool and tool:FindFirstChild("Level")
    if levelValue then
        return tonumber(levelValue.Value) or 0
    end

    local lookup = {}
    for _, name in ipairs(names or {}) do
        local normalizedName = normalizeStyleLookupName(name)
        if normalizedName then
            lookup[normalizedName] = true
        end
    end

    for _, item in ipairs(refreshDetailedInventoryCache(false)) do
        if type(item) == "table" then
            local normalizedName = normalizeStyleLookupName(item.Name or item.name)
            if normalizedName and lookup[normalizedName] then
                local mastery = tonumber(item.Mastery or item.mastery or item.MasteryLevel or item.masteryLevel or item.Level or item.level)
                if mastery then
                    return mastery
                end
            end
        end
    end

    return nil
end

