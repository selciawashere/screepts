local isCopying = false -- Debounce variable
CopyButton.MouseButton1Click:Connect(function()
    if isCopying then return end -- Prevent double clicks
    
    if setclipboard then
        isCopying = true
        setclipboard(CONFIG.DiscordLink)
        
        -- FIX: Prevent text overwriting bug
        local originalText = "Copy Invite Link"
        CopyButton.Text = "Copied!"
        
        TweenService:Create(CopyButton, TweenInfo.new(0.2), {
            BackgroundColor3 = Color3.fromRGB(40, 255, 100), 
            BackgroundTransparency = 0.6, 
            TextColor3 = Color3.fromRGB(255, 255, 255)
        }):Play()
        
        task.wait(1.5)
        
        if CopyButton.Parent then
            CopyButton.Text = originalText
            TweenService:Create(CopyButton, TweenInfo.new(0.3), {
                BackgroundColor3 = Color3.fromRGB(40, 255, 100), 
                BackgroundTransparency = 0.8, 
                TextColor3 = Color3.fromRGB(255, 255, 255)
            }):Play()
        end
        isCopying = false
    end
end)

