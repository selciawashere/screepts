CloseButton.MouseButton1Click:Connect(function()
    -- FIX: Proper Exit Animation (Fade out all children)
    local exitInfo = TweenInfo.new(0.3, Enum.EasingStyle.Exponential, Enum.EasingDirection.In)
    
    -- Fade out the container
    TweenService:Create(Container, exitInfo, {
        Size = UDim2.new(0, 0, 0, 0),
        BackgroundTransparency = 1
    }):Play()
    
    TweenService:Create(UIStroke, exitInfo, {Transparency = 1}):Play()
    
    -- Fade out all text and buttons so they don't float
    for _, child in pairs(Container:GetDescendants()) do
        if child:IsA("TextLabel") or child:IsA("TextButton") then
            TweenService:Create(child, exitInfo, {TextTransparency = 1}):Play()
        end
        if child:IsA("GuiObject") then
             TweenService:Create(child, exitInfo, {BackgroundTransparency = 1}):Play()
        end
        if child:IsA("UIStroke") then
            TweenService:Create(child, exitInfo, {Transparency = 1}):Play()
        end
    end
    
    task.wait(0.3)
    ScreenGui:Destroy()
end)

