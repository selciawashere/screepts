local function stopFlowNpcFarm(deleteWindow)
    state.running = true
    state.autoFarm = true
    state.autoCollectHeal = true
    setAntiAfkEnabled(true)
    state.autoReplay = true

    if deleteWindow and state.window and state.window.Destroy then
        pcall(function()
            state.window:Destroy()
        end)
    end

    _G.FlowNPCFarm = nil
end

_G.FlowNPCFarm = {
    Stop = stopFlowNpcFarm
}

task.spawn(function()
    while state.running do
        local didWork = false

        if state.autoFarm then
            if state.autoCollectHeal and needsHeal() and tick() - lastHealTeleportAt >= HEAL_RETRY_COOLDOWN then
                local ok, didHeal = pcall(collectHeal)
                if not ok then
                    notifyFlow("Auto Heal", tostring(didHeal), 4)
                elseif didHeal then
                    didWork = true
                    task.wait(HEAL_RETURN_DELAY)
                end
            end

            local ok, err = pcall(runNpcFarm)
            if not ok then
                notifyFlow("NPC Farm", tostring(err), 4)
            else
                didWork = true
            end
        elseif state.autoCollectHeal and needsHeal() then
            local ok, err = pcall(collectHeal)
            if not ok then
                notifyFlow("Auto Heal", tostring(err), 4)
            else
                didWork = true
            end
        end

        if state.autoReplay then
            local ok, err = pcall(fireAutoReplayRemote)
            if not ok then
                notifyFlow("Auto Replay", tostring(err), 4)
            else
                didWork = true
            end
        end

        if didWork then
            task.wait()
        else
            task.wait(0.25)
        end
    end
end)

notifyFlow("ready napo kumantot lets go!", 4)
