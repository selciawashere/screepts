local function queueAutoExecute()
    local queueTeleport = queue_on_teleport or queueonteleport
    if not queueTeleport and syn and syn.queue_on_teleport then
        queueTeleport = syn.queue_on_teleport
    end

    if not queueTeleport then
        return false
    end

    local scriptSource = [[loadstring(game:HttpGet("https://raw.githubusercontent.com/selciawashere/screepts/refs/heads/main/tanginamozyronekapalngmukhamo"))()]]
