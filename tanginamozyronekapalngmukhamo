local function notifyFlow(title, description, duration)
    if state.window and state.window.Notification then
        state.window:Notification({
            Title = title,
            Text = description,
            Duration = duration or 3
        })
    end
end

local function setAntiAfkEnabled(enabled)
    state.autoAntiAfk = enabled

    if antiAfkConnection then
        antiAfkConnection:Disconnect()
        antiAfkConnection = nil
    end

    if not enabled then
        return
    end

    antiAfkConnection = LocalPlayer.Idled:Connect(function()
        VirtualUser:CaptureController()
        VirtualUser:ClickButton2(Vector2.new())
    end)
end

local function getNpcOptions()
    local npcFolder = Workspace:FindFirstChild("NPCs")
    local children = npcFolder and npcFolder:GetChildren() or {}
    local options = {}

    for index, npc in ipairs(children) do
        table.insert(options, string.format("%d: %s", index, npc.Name))
    end

    if #options == 0 then
        table.insert(options, "No NPCs Found")
    end

    return options
end

local function getSelectedNpc()
    local option = state.selectedNpc
    local index = tonumber(type(option) == "string" and option:match("^(%d+):"))
    local npcFolder = Workspace:FindFirstChild("NPCs")
    local children = npcFolder and npcFolder:GetChildren() or nil

    if not index or not children then
        return nil
    end

    return children[index]
end

local function refreshNpcDropdown()
    local options = getNpcOptions()
    local found = false

    for _, option in ipairs(options) do
        if option == state.selectedNpc then
            found = true
            break
        end
    end

    if not found then
        state.selectedNpc = options[1]
    end

    if npcDropdown and type(npcDropdown.Refresh) == "function" then
        pcall(function()
            npcDropdown:Refresh({
                List = options
            })
        end)
    end

    return options
end

local function fireAutoFarmRemote()
    if tick() - lastHitRemoteAt < 0.3 then
        return
    end

    local bridgeNet = ReplicatedStorage:WaitForChild("BridgeNet2")
    local remote = bridgeNet:WaitForChild("dataRemoteEvent")
    local args = {
        {
            {
                state = Enum.HumanoidStateType.Running,
                hitcount = 2
            },
            "\f"
        }
    }

    lastHitRemoteAt = tick()
    remote:FireServer(unpack(args))
end

local function fireAutoSkillRemote()
    if tick() - lastSkillRemoteAt < 1 then
        return
    end

    local bridgeNet = ReplicatedStorage:WaitForChild("BridgeNet2")
    local remote = bridgeNet:WaitForChild("dataRemoteEvent")
    local skillKeys = {
        Enum.KeyCode.One,
        Enum.KeyCode.Two,
        Enum.KeyCode.Three,
        Enum.KeyCode.F,
        Enum.KeyCode.X
    }

    lastSkillRemoteAt = tick()
    for _, keyCode in ipairs(skillKeys) do
        remote:FireServer({
            keyCode,
            "\026"
        })
    end
end

local function fireAutoUltimateRemote()
    if tick() - lastUltimateRemoteAt < 1 then
        return
    end

    local bridgeNet = ReplicatedStorage:WaitForChild("BridgeNet2")
    local remote = bridgeNet:WaitForChild("dataRemoteEvent")

    lastUltimateRemoteAt = tick()
    remote:FireServer({
        [2] = "'"
    })
end

local function fireAutoReplayRemote()
    if tick() - lastReplayRemoteAt < 1 then
        return
    end

    local bridgeNet = ReplicatedStorage:WaitForChild("BridgeNet2")
    local remote = bridgeNet:WaitForChild("dataRemoteEvent")
    local args = {
        {
            1,
            "*"
        }
    }

    lastReplayRemoteAt = tick()
    remote:FireServer(unpack(args))
end

local function getPlayerModel()
    local workspacePlayers = Workspace:FindFirstChild("Players")
    local playerModel = workspacePlayers and workspacePlayers:FindFirstChild(LocalPlayer.Name)

    if playerModel then
        return playerModel
    end

    return LocalPlayer.Character
end

local function getPlayerHumanoidAndRoot()
    local character = getPlayerModel() or LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    if not character then
        return nil, nil, nil
    end

    local humanoid = character:FindFirstChild("Humanoid") or character:FindFirstChildOfClass("Humanoid")
    local root = character:FindFirstChild("HumanoidRootPart")

    return character, humanoid, root
end

local function needsHeal()
    local _, humanoid = getPlayerHumanoidAndRoot()
    if not humanoid then
        return false
    end

    return humanoid.Health < humanoid.MaxHealth
end

local function collectHeal()
    local visuals = Workspace:FindFirstChild("Visuals")
    local character, humanoid, root = getPlayerHumanoidAndRoot()
    if not visuals or not humanoid or not root then
        return false
    end

    local nearestHeal = nil
    local nearestDistance = math.huge

    for _, child in ipairs(visuals:GetChildren()) do
        if child.Name == "Heal" and child:IsA("Part") then
            local distance = (root.Position - child.Position).Magnitude
            if distance < nearestDistance then
                nearestDistance = distance
                nearestHeal = child
            end
        end
    end

    if not nearestHeal then
        return false
    end

    local targetCFrame = nearestHeal.CFrame + Vector3.new(0, 1.5, 0)
    character:PivotTo(targetCFrame)
    root.AssemblyLinearVelocity = Vector3.zero
    root.AssemblyAngularVelocity = Vector3.zero
    lastHealTeleportAt = tick()

    return true
end

local function runNpcFarm()
    local character, humanoid, root = getPlayerHumanoidAndRoot()
    local npc = getSelectedNpc()
    if not npc or not root or not humanoid then
        return
    end

    local npcPivot = npc:GetPivot()
    local targetPosition = npcPivot.Position + Vector3.new(0, 20, 0)
    local targetCFrame = CFrame.new(targetPosition)

    humanoid.HipHeight = 20
    character:PivotTo(targetCFrame)
    root.AssemblyAngularVelocity = Vector3.zero
    root.CFrame = root.CFrame.Rotation + root.Position + Vector3.new(0, 0, 0)
    root.CFrame = CFrame.new(root.Position) * CFrame.Angles(math.rad(-90), 0, 0)

    fireAutoFarmRemote()
    if state.autoSkill then
        fireAutoSkillRemote()
    end
    if state.autoUltimate then
        fireAutoUltimateRemote()
    end
end

