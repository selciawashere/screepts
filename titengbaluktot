local function updateStatusUI()
    local mobileMode = isMobileMode()

    statusFrame.Size = UDim2.new(0, FRAME_WIDTH, 0, getFrameHeight())
    contentFrame.Visible = not isMinimized
    divider.Visible = not isMinimized
    minimizeButton.Text = isMinimized and "+" or "-"

    modeChip.Text = mobileMode and "MOBILE" or "PC"
    modeChip.TextColor3 = mobileMode and Color3.fromRGB(109, 214, 255) or Color3.fromRGB(255, 210, 96)
    modeChip.BackgroundColor3 = mobileMode and Color3.fromRGB(24, 52, 74) or Color3.fromRGB(52, 43, 22)

    statusButton.Text = isEnabled and "ON" or "OFF"
    statusButton.BackgroundColor3 = isEnabled and Color3.fromRGB(61, 194, 116) or Color3.fromRGB(216, 77, 77)

    modeLabel.Text = mobileMode and "MOBILE MODE ACTIVE" or "PC MODE ACTIVE"
    targetLabel.Text = "Target: " .. (targetPlayer and targetPlayer.Name or "None")

    if mobileMode then
        aimPointLabel.Text = "Aim Point: " .. (lastTouchPosition and "Touch Position" or "Screen Center")
        hintLabel.Text = "Drag the title bar to move this UI. Tap OFF/ON or the button below to toggle silent aim."
        hintLabel.TextColor3 = Color3.fromRGB(104, 196, 255)
    else
        aimPointLabel.Text = "Aim Point: Mouse Cursor"
        hintLabel.Text = "Press X to toggle silent aim on PC. You can also drag or minimize this panel."
        hintLabel.TextColor3 = Color3.fromRGB(104, 214, 165)
    end

    mobileToggle.Visible = mobileMode and not isMinimized
    mobileToggle.Text = isEnabled and "Disable Silent Aim" or "Enable Silent Aim"
    mobileToggle.BackgroundColor3 = isEnabled and Color3.fromRGB(61, 194, 116) or Color3.fromRGB(53, 119, 255)

    crosshairOuter.Visible = mobileMode
end

local function setEnabled(value)
    isEnabled = value

    if not isEnabled then
        targetPlayer = nil
        isLeftMouseDown = false
        isRightMouseDown = false
        stopAutoClick()
    end

    updateStatusUI()
end

local function getAimPosition()
    if isMobileMode() then
        if lastTouchPosition then
            return lastTouchPosition
        end

        local viewportSize = camera.ViewportSize
        return Vector2.new(viewportSize.X * 0.5, viewportSize.Y * 0.5)
    end

    return UserInputService:GetMouseLocation()
end

local function getClosestPlayerToPoint(screenPoint)
    local closest = nil
    local minDist = math.huge

    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= localPlayer and player.Character then
            local head = player.Character:FindFirstChild("Head")
            local humanoid = player.Character:FindFirstChildOfClass("Humanoid")

            if head and humanoid and humanoid.Health > 0 then
                local position, onScreen = camera:WorldToViewportPoint(head.Position)

                if onScreen then
                    local headPoint = Vector2.new(position.X, position.Y)
                    local distance = (headPoint - screenPoint).Magnitude

                    if distance < minDist then
                        closest = player
                        minDist = distance
                    end
                end
            end
        end
    end

    return closest
end

local function lockCameraToHead()
    if not isEnabled then
        return
    end

    if targetPlayer and targetPlayer.Character and targetPlayer.Character:FindFirstChild("Head") then
        local head = targetPlayer.Character.Head
        local position = camera:WorldToViewportPoint(head.Position)

        if position.Z > 0 then
            local cameraPosition = camera.CFrame.Position
            camera.CFrame = CFrame.new(cameraPosition, head.Position)
        end
    end
end

local function autoClick()
    if not isEnabled then
        return
    end

    stopAutoClick()

    autoClickConnection = RunService.Heartbeat:Connect(function()
        if not isEnabled or not (isLeftMouseDown or isRightMouseDown) then
            stopAutoClick()
            return
        end

        if isLobbyVisible() then
            return
        end

        local now = tick()
        if now - lastClickTime >= clickInterval then
            if typeof(mouse1click) == "function" then
                mouse1click()
            end

            lastClickTime = now
        end
    end)
end

local function beginDrag(input)
    isDraggingFrame = true
    dragStart = input.Position
    frameStartPosition = statusFrame.Position
    dragInput = input

    input.Changed:Connect(function()
        if input.UserInputState == Enum.UserInputState.End then
            isDraggingFrame = false
            dragInput = nil
        end
    end)
end

local function updateDrag(input)
    if not dragStart or not frameStartPosition then
        return
    end

    local delta = input.Position - dragStart
    statusFrame.Position = UDim2.new(
        frameStartPosition.X.Scale,
        frameStartPosition.X.Offset + delta.X,
        frameStartPosition.Y.Scale,
        frameStartPosition.Y.Offset + delta.Y
    )
end

local function isInputOnStatusFrame(input)
    if not input.Position then
        return false
    end

    local point = Vector2.new(input.Position.X, input.Position.Y)
    return isPointInsideGuiObject(point, statusFrame)
end

dragHandle.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
        beginDrag(input)
    end
end)

dragHandle.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseMovement then
        dragInput = input
    end
end)

statusButton.MouseButton1Click:Connect(function()
    setEnabled(not isEnabled)
end)

mobileToggle.MouseButton1Click:Connect(function()
    setEnabled(not isEnabled)
end)

minimizeButton.MouseButton1Click:Connect(function()
    isMinimized = not isMinimized
    updateStatusUI()
end)

UserInputService.LastInputTypeChanged:Connect(function()
    updateStatusUI()
end)

UserInputService.InputBegan:Connect(function(input, processed)
    local onStatusFrame = isInputOnStatusFrame(input)

    if input.UserInputType == Enum.UserInputType.Touch and input.Position and not onStatusFrame and not isDraggingFrame then
        lastTouchPosition = Vector2.new(input.Position.X, input.Position.Y)
        updateStatusUI()
    end

    if input.KeyCode == Enum.KeyCode.X and not processed and not isMobileMode() then
        setEnabled(not isEnabled)
        return
    end

    if onStatusFrame or not isEnabled then
        return
    end

    if input.UserInputType == Enum.UserInputType.MouseButton1 and not processed then
        if not isLeftMouseDown then
            isLeftMouseDown = true
            autoClick()
        end
    elseif input.UserInputType == Enum.UserInputType.MouseButton2 and not processed then
        if not isRightMouseDown then
            isRightMouseDown = true
            autoClick()
        end
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if isDraggingFrame and input == dragInput then
        updateDrag(input)
        return
    end

    if input.UserInputType == Enum.UserInputType.Touch and input.Position and not isInputOnStatusFrame(input) then
        lastTouchPosition = Vector2.new(input.Position.X, input.Position.Y)
        updateStatusUI()
    end
end)

UserInputService.InputEnded:Connect(function(input, processed)
    if input == dragInput then
        isDraggingFrame = false
        dragInput = nil
    end

    if input.UserInputType == Enum.UserInputType.Touch then
        lastTouchPosition = nil
        updateStatusUI()
        return
    end

    if not isEnabled then
        return
    end

    if input.UserInputType == Enum.UserInputType.MouseButton1 and not processed then
        isLeftMouseDown = false
    elseif input.UserInputType == Enum.UserInputType.MouseButton2 and not processed then
        isRightMouseDown = false
    end
end)

RunService.Heartbeat:Connect(function()
    camera = workspace.CurrentCamera

    if not isLobbyVisible() and isEnabled then
        targetPlayer = getClosestPlayerToPoint(getAimPosition())

        if targetPlayer then
            lockCameraToHead()
        end
    else
        targetPlayer = nil
    end

    updateStatusUI()
end)

updateStatusUI()
